#!/bin/bash
# Deploy to production
# Usage:
#   ./deploy                    # Standard deploy
#   ./deploy --branch feature   # Deploy specific branch
#   ./deploy --force            # Force deploy (even if no changes)
#   ./deploy --rollback         # Rollback to previous release

set -euo pipefail

ANSIBLE_DIR="${ANSIBLE_DIR:-$HOME/code/ansible-deploy}"
SITE="solutionsdelivered"
VAULT_FILE="$HOME/.ansible_vault_password"

if [ ! -d "$ANSIBLE_DIR" ]; then
    echo "Error: ansible-deploy not found at $ANSIBLE_DIR"
    echo "Set ANSIBLE_DIR to override."
    exit 1
fi

if [ ! -f "$VAULT_FILE" ]; then
    echo "Error: vault password file not found at $VAULT_FILE"
    exit 1
fi

# Parse arguments
PLAYBOOK="deploy.yml"
EXTRA_VARS=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --rollback)
            PLAYBOOK="rollback.yml"
            shift
            ;;
        --branch)
            EXTRA_VARS="$EXTRA_VARS -e git_branch=$2"
            shift 2
            ;;
        --force)
            EXTRA_VARS="$EXTRA_VARS -e force_deploy=true"
            shift
            ;;
        --no-migrations)
            EXTRA_VARS="$EXTRA_VARS -e run_migrations=false"
            shift
            ;;
        --dry-run)
            EXTRA_VARS="$EXTRA_VARS --check"
            shift
            ;;
        *)
            echo "Unknown option: $1"
            echo "Usage: ./deploy [--branch NAME] [--force] [--no-migrations] [--rollback] [--dry-run]"
            exit 1
            ;;
    esac
done

cd "$ANSIBLE_DIR"
exec ansible-playbook "$PLAYBOOK" -e "site=$SITE" --vault-password-file "$VAULT_FILE" $EXTRA_VARS
